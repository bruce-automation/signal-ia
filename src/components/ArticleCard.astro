---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
}

const { article } = Astro.props;
const { title, description, category, pubDate } = article.data;
const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
---

<article class="card">
  <div class="kicker"><a href={`${baseUrl}categories/${category}/`}>{category}</a></div>
  <h3><a href={`${baseUrl}articles/${article.id}/`}>{title}</a></h3>
  <p>{description}</p>
  <div class="meta">{pubDate.toLocaleDateString('fr-FR')}</div>
</article>
