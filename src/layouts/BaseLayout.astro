---
import '../styles/global.css';
import { siteDescription, siteName, socialImage, subscribeMailto } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article';
  image?: string;
  noTitleSuffix?: boolean;
  lang?: string;
  ogLocale?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonical,
  type = 'website',
  image = socialImage,
  noTitleSuffix = false,
  lang = 'en',
  ogLocale = 'en_US',
  structuredData,
} = Astro.props;

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
const pageTitle = noTitleSuffix ? title : `${title} | ${siteName}`;
const siteRoot = new URL(baseUrl, Astro.site);
const url = new URL(Astro.url.pathname, Astro.site);

function normalizeCanonical(input: string) {
  const parsed = new URL(input);
  const pathname = parsed.pathname;
  const looksLikeFile = /\.[a-z0-9]+$/i.test(pathname);

  if (!looksLikeFile && !pathname.endsWith('/')) {
    parsed.pathname = `${pathname}/`;
  }

  return parsed.toString();
}

const canonicalUrl = normalizeCanonical(canonical ?? url.toString());
const imageUrl = new URL(image.replace(/^\//, ''), siteRoot).toString();
const sitemapUrl = new URL(`${basePath ? `${basePath}/` : ''}sitemap-index.xml`, Astro.site).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href={sitemapUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0b1020" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={siteDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script
      data-goatcounter="https://signal-ia-bruce.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={baseUrl} class="brand">{siteName}</a>
        <nav class="nav">
          <a href={`${baseUrl}articles/`}>Articles</a>
          <a href={`${baseUrl}categories/`}>Categories</a>
          <a href={`${baseUrl}dossiers/`}>Topics</a>
          <a href={`${baseUrl}about/`}>About</a>
          <a href={`${baseUrl}contact/`}>Contact</a>
          <a href={`${baseUrl}rss.xml`}>RSS</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner footer-stack">
        <section class="signup-panel">
          <div>
            <div class="eyebrow">Signal IA brief</div>
            <h2>Get the useful AI signal, not the noise.</h2>
            <p>Subscribe to the editorial brief for practical AI analysis, comparisons, and updates worth your time.</p>
          </div>
          <div class="cta-row signup-actions">
            <a class="button primary" href={subscribeMailto}>Subscribe by email</a>
            <a class="button" href={`${baseUrl}rss.xml`}>Follow by RSS</a>
          </div>
        </section>
        <p>{siteDescription}</p>
        <nav class="nav footer-nav" aria-label="Footer">
          <a href={`${baseUrl}about/`}>About</a>
          <a href={`${baseUrl}editorial-policy/`}>Editorial Policy</a>
          <a href={`${baseUrl}author/`}>Author</a>
          <a href={`${baseUrl}contact/`}>Contact</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
