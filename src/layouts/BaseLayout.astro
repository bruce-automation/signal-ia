---
import '../styles/global.css';
import { siteDescription, siteName, socialImage } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article';
  image?: string;
  noTitleSuffix?: boolean;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonical,
  type = 'website',
  image = socialImage,
  noTitleSuffix = false,
  structuredData,
} = Astro.props;

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
const pageTitle = noTitleSuffix ? title : `${title} | ${siteName}`;
const siteRoot = new URL(baseUrl, Astro.site);
const url = new URL(Astro.url.pathname, Astro.site);
const canonicalUrl = canonical ?? url.toString();
const imageUrl = new URL(image.replace(/^\//, ''), siteRoot).toString();
const sitemapUrl = new URL(`${basePath ? `${basePath}/` : ''}sitemap-index.xml`, Astro.site).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href={sitemapUrl} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0b1020" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={siteDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    <script
      data-goatcounter="https://signal-ia-bruce.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={baseUrl} class="brand">{siteName}</a>
        <nav class="nav">
          <a href={`${baseUrl}articles/`}>Articles</a>
          <a href={`${baseUrl}categories/`}>Catégories</a>
          <a href={`${baseUrl}dossiers/`}>Dossiers</a>
          <a href={`${baseUrl}rss.xml`}>RSS</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <p>{siteDescription}</p>
      </div>
    </footer>
  </body>
</html>
