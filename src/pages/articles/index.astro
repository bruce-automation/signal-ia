---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categoryMeta, pillarPages } from '../../data/seo';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout
  title="Articles"
  description="Tous les articles Signal IA : comparatifs, guides, agents, outils et business."
>
  <section class="list-page-header">
    <div class="eyebrow">Archives</div>
    <h1>Tous les articles</h1>
    <p>Un index simple, lisible, maintenable.</p>
    <div class="cta-row">
      <a class="button" href={`${baseUrl}categories/`}>Voir les catégories</a>
      <a class="button" href={`${baseUrl}dossiers/`}>Voir les dossiers</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Explorer</div>
        <h2>Entrer par une intention de recherche</h2>
      </div>
    </div>
    <div class="tag-row">
      {Object.entries(categoryMeta).map(([slug, meta]) => (
        <a class="tag" href={`${baseUrl}categories/${slug}/`}>{meta.title}</a>
      ))}
      {pillarPages.map((page) => (
        <a class="tag" href={`${baseUrl}dossiers/${page.slug}/`}>{page.title}</a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="grid cards">
      {articles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
