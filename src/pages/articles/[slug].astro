---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getArticleLanguage,
  getArticleOgLocale,
  getArticleRouteSlugs,
  getArticleSchemaLanguage,
  getArticleSlug,
  getArticles,
} from '../../data/articles';
import { categoryMeta } from '../../data/seo';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';

export async function getStaticPaths() {
  const articles = await getArticles();

  return articles.flatMap((article) => {
    const canonicalSlug = getArticleSlug(article);

    return getArticleRouteSlugs(article).map((slug) => ({
      params: { slug },
      props: {
        article,
        requestedSlug: slug,
        isCanonical: slug === canonicalSlug,
      },
    }));
  });
}

const { article, requestedSlug, isCanonical } = Astro.props;
const { Content } = await render(article);
const canonicalPath = `${baseUrl}articles/${getArticleSlug(article)}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site).toString();
const articleLanguage = getArticleLanguage(article);
const categoryLabel = categoryMeta[article.data.category].title;
const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: new URL(baseUrl, Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Articles',
      item: new URL(`${baseUrl}articles/`, Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.data.title,
      item: canonicalUrl,
    },
  ],
};
const articleData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.pubDate.toISOString(),
  dateModified: article.data.pubDate.toISOString(),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  inLanguage: getArticleSchemaLanguage(article),
  articleSection: categoryLabel,
  author: {
    '@type': 'Organization',
    name: 'Signal IA',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Signal IA',
  },
};
const legacyStructuredData = !isCanonical
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      url: new URL(`${baseUrl}articles/${requestedSlug}/`, Astro.site).toString(),
      isPartOf: canonicalUrl,
    }
  : undefined;
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  type="article"
  lang={articleLanguage}
  ogLocale={getArticleOgLocale(article)}
  canonical={canonicalUrl}
  structuredData={legacyStructuredData ? [breadcrumbData, articleData, legacyStructuredData] : [breadcrumbData, articleData]}
>
  {!isCanonical && (
    <meta http-equiv="refresh" content={`0;url=${canonicalPath}`} />
  )}

  <article class="article-shell">
    {!isCanonical && (
      <p class="meta">
        This article moved to <a href={canonicalPath}>{canonicalPath}</a>.
      </p>
    )}
    <nav class="meta" aria-label="Breadcrumb">
      <a href={`${baseUrl}articles/`}>Articles</a> · <a href={`${baseUrl}categories/${article.data.category}/`}>{categoryLabel}</a>
    </nav>
    <div class="kicker"><a href={`${baseUrl}categories/${article.data.category}/`}>{categoryLabel}</a></div>
    <h1>{article.data.title}</h1>
    <p class="meta">Published on {article.data.pubDate.toLocaleDateString(articleLanguage === 'en' ? 'en-GB' : 'fr-FR')}</p>
    <Content />
  </article>
</BaseLayout>
