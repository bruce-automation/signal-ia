---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Accueil',
      item: new URL(baseUrl, Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Articles',
      item: new URL(`${baseUrl}articles/`, Astro.site).toString(),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.data.title,
      item: canonicalUrl,
    },
  ],
};
const articleData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.pubDate.toISOString(),
  dateModified: article.data.pubDate.toISOString(),
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  inLanguage: 'fr-FR',
  articleSection: article.data.category,
  author: {
    '@type': 'Organization',
    name: 'Signal IA',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Signal IA',
  },
};
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  type="article"
  structuredData={[breadcrumbData, articleData]}
>
  <article class="article-shell">
    <nav class="meta" aria-label="Fil d’Ariane">
      <a href={`${baseUrl}articles/`}>Articles</a> · <a href={`${baseUrl}categories/${article.data.category}/`}>{article.data.category}</a>
    </nav>
    <div class="kicker"><a href={`${baseUrl}categories/${article.data.category}/`}>{article.data.category}</a></div>
    <h1>{article.data.title}</h1>
    <p class="meta">Publié le {article.data.pubDate.toLocaleDateString('fr-FR')}</p>
    <Content />
  </article>
</BaseLayout>
