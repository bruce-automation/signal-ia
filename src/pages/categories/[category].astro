---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { categoryMeta, type CategorySlug } from '../../data/seo';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';

export async function getStaticPaths() {
  return Object.entries(categoryMeta).map(([category, meta]) => ({
    params: { category },
    props: { category, meta },
  }));
}

const { category, meta } = Astro.props as {
  category: CategorySlug;
  meta: (typeof categoryMeta)[CategorySlug];
};

const articles = (await getCollection('articles'))
  .filter((article) => article.data.category === category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = articles.find((article) => article.data.featured) ?? articles[0];
const others = featured ? articles.filter((article) => article.id !== featured.id) : articles;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: meta.title,
  description: meta.description,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  inLanguage: 'fr-FR',
  isPartOf: new URL(baseUrl, Astro.site).toString(),
};
---

<BaseLayout title={meta.title} description={meta.description} structuredData={structuredData}>
  <section class="list-page-header">
    <div class="eyebrow">Catégorie</div>
    <h1>{meta.title}</h1>
    <p>{meta.intro}</p>
  </section>

  {featured && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">À lire en premier</div>
          <h2>{featured.data.title}</h2>
        </div>
      </div>
      <article class="feature-panel">
        <p>{featured.data.description}</p>
        <div class="cta-row">
          <a class="button primary" href={`${baseUrl}articles/${featured.id}/`}>Lire l’article</a>
          <a class="button" href={`${baseUrl}articles/`}>Voir tous les articles</a>
        </div>
      </article>
    </section>
  )}

  {others.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">Archives utiles</div>
          <h2>Autres contenus {meta.title.toLowerCase()}</h2>
        </div>
      </div>
      <div class="grid cards">
        {others.map((article: CollectionEntry<'articles'>) => <ArticleCard article={article} />)}
      </div>
    </section>
  )}
</BaseLayout>
