---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { categoryMeta } from '../../data/seo';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
---

<BaseLayout
  title="Categories"
  description="Browse Signal IA by editorial categories: comparisons, guides, agents, business, and tools."
  lang="en"
  ogLocale="en_US"
>
  <section class="list-page-header">
    <div class="eyebrow">Taxonomy</div>
    <h1>Categories</h1>
    <p>Simple entry points for finding the right angle faster.</p>
  </section>

  <section class="section">
    <div class="grid cards">
      {Object.entries(categoryMeta).map(([slug, meta]) => (
        <article class="card">
          <div class="kicker">{slug}</div>
          <h3><a href={`${baseUrl}categories/${slug}/`}>{meta.title}</a></h3>
          <p>{meta.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
