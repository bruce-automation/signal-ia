---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getArticles } from '../data/articles';
import { categoryMeta, pillarPages } from '../data/seo';
import { siteName, siteTagline, socialImage, subscribeMailto } from '../data/site';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
const articles = (await getArticles()).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const featured = articles.filter((article) => article.data.featured).slice(0, 3);
const guides = articles.filter((article) => article.data.category === 'guides').slice(0, 3);
const comparisons = articles.filter((article) => article.data.category === 'comparisons').slice(0, 3);
const baseSiteUrl = new URL(baseUrl, Astro.site).toString();
const socialImageUrl = new URL(socialImage.replace(/^\//, ''), new URL(baseUrl, Astro.site)).toString();
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  description: siteTagline,
  url: baseSiteUrl,
  inLanguage: 'en',
  image: socialImageUrl,
};
---

<BaseLayout
  title="Signal IA"
  description={siteTagline}
  noTitleSuffix={true}
  lang="en"
  ogLocale="en_US"
  structuredData={structuredData}
>
  <section class="hero">
    <div class="eyebrow">Signal IA</div>
    <h1>The AI publication that filters the noise.</h1>
    <p>
      Comparisons, guides, agents, tools, business: we cut through the hype and keep the signal.
    </p>
    <div class="cta-row">
      <a class="button primary" href={`${baseUrl}articles/`}>Browse latest analysis</a>
      <a class="button" href={`${baseUrl}categories/comparisons/`}>Read comparisons</a>
      <a class="button" href={`${baseUrl}categories/guides/`}>Explore guides</a>
    </div>
    <div class="tag-row">
      <span class="tag">Comparisons</span>
      <span class="tag">Practical guides</span>
      <span class="tag">Agents</span>
      <span class="tag">Business</span>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Latest analysis</div>
        <h2>What actually matters</h2>
      </div>
      <p>No conference noise, no AI panic. Just the pieces that help you understand, choose, and act.</p>
    </div>
    <div class="grid cards">
      {featured.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="section signup-panel signup-panel-inline">
    <div>
      <div class="eyebrow">Signal IA brief</div>
      <h2>Get practical AI analysis without inbox sludge.</h2>
      <p>Subscribe to receive the useful Signal IA brief: strong comparisons, real workflow takeaways, and fewer recycled launch headlines.</p>
    </div>
    <div class="cta-row signup-actions">
      <a class="button primary" href={subscribeMailto}>Get the brief</a>
      <a class="button" href={`${baseUrl}rss.xml`}>Prefer RSS</a>
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Practical guides</div>
        <h2>Articles built for working with AI, not admiring it.</h2>
      </div>
    </div>
    <div class="grid cards">
      {guides.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Comparisons</div>
        <h2>Compare options before you buy slogans.</h2>
      </div>
    </div>
    <div class="grid cards">
      {comparisons.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Explore by topic</div>
        <h2>Start from the angle that fits your question</h2>
      </div>
      <p>Browse by category or go straight to a deeper topic page.</p>
    </div>
    <div class="tag-row">
      {Object.entries(categoryMeta).map(([slug, meta]) => (
        <a class="tag" href={`${baseUrl}categories/${slug}/`}>{meta.title}</a>
      ))}
    </div>
    <div class="grid cards">
      {pillarPages.map((page) => (
        <article class="card">
          <div class="kicker">topic guide</div>
          <h3><a href={`${baseUrl}dossiers/${page.slug}/`}>{page.title}</a></h3>
          <p>{page.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
