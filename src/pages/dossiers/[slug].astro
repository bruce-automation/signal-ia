---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { pillarPages, type PillarPage } from '../../data/seo';
import { getArticleUrl } from '../../data/articles';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';

export async function getStaticPaths() {
  return pillarPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: PillarPage };
const allArticles = await getCollection('articles');
const featuredIdSet = new Set(page.featuredArticleIds);
const matchesFeaturedId = (article: CollectionEntry<'articles'>) => {
  const normalizedId = article.id.replace(/\.md$/, '');
  return (
    featuredIdSet.has(article.id) ||
    featuredIdSet.has(normalizedId) ||
    featuredIdSet.has(article.data.slug) ||
    (article.data.redirectFrom ?? []).some((legacySlug) => featuredIdSet.has(legacySlug))
  );
};

const featuredArticles = allArticles.filter(matchesFeaturedId);

const relatedArticles = allArticles
  .filter(
    (article) =>
      page.categories.includes(article.data.category) &&
      !matchesFeaturedId(article),
  )
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: page.title,
  description: page.description,
  url: canonicalUrl,
  inLanguage: 'en-US',
  hasPart: featuredArticles.map((article) => ({
    '@type': 'BlogPosting',
    headline: article.data.title,
    url: new URL(getArticleUrl(article, baseUrl), Astro.site).toString(),
  })),
  mainEntity: page.faqs?.length
    ? {
        '@type': 'FAQPage',
        mainEntity: page.faqs.map((faq) => ({
          '@type': 'Question',
          name: faq.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: faq.answer,
          },
        })),
      }
    : undefined,
};
---

<BaseLayout title={page.title} description={page.description} lang="en" ogLocale="en_US" structuredData={structuredData}>
  <section class="list-page-header">
    <div class="eyebrow">{page.eyebrow}</div>
    <h1>{page.title}</h1>
    <p>{page.intro}</p>
    <div class="tag-row">
      {page.categories.map((category) => (
        <a class="tag" href={`${baseUrl}categories/${category}/`}>{category}</a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Overview</div>
        <h2>The editorial foundation for this topic</h2>
      </div>
    </div>
    <div class="feature-panel longform-panel">
      {page.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </section>

  {page.quickWins && page.quickWins.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">Quick takeaways</div>
          <h2>The rules that prevent most mistakes</h2>
        </div>
      </div>
      <div class="grid quick-grid">
        {page.quickWins.map((item) => (
          <article class="card quick-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {page.sections && page.sections.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">Long-form guide</div>
          <h2>The full hub</h2>
        </div>
      </div>
      <div class="stacked-sections">
        {page.sections.map((section) => (
          <article class="feature-panel longform-panel">
            <h3>{section.title}</h3>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Start here</div>
        <h2>The most useful articles</h2>
      </div>
    </div>
    <div class="grid cards">
      {featuredArticles.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  {page.checklist && page.checklist.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">Checklist</div>
          <h2>Keep these close</h2>
        </div>
      </div>
      <div class="grid cards">
        {page.checklist.map((list) => (
          <article class="card checklist-card">
            <h3>{list.title}</h3>
            <ul>
              {list.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>
  )}

  {relatedArticles.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">Go deeper</div>
          <h2>Related coverage</h2>
        </div>
      </div>
      <div class="grid cards">
        {relatedArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </section>
  )}

  {page.faqs && page.faqs.length > 0 && (
    <section class="section">
      <div class="section-head">
        <div>
          <div class="eyebrow">FAQ</div>
          <h2>Common questions</h2>
        </div>
      </div>
      <div class="stacked-sections">
        {page.faqs.map((faq) => (
          <article class="feature-panel longform-panel faq-item">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
