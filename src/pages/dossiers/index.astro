---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pillarPages } from '../../data/seo';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
---

<BaseLayout
  title="Guides"
  description="Signal IA pillar pages that group the strongest content clusters by strategic topic."
  lang="en"
  ogLocale="en_US"
>
  <section class="list-page-header">
    <div class="eyebrow">Editorial hub</div>
    <h1>Guides</h1>
    <p>Topic hubs designed to capture broad search intent and route readers to the right articles.</p>
  </section>

  <section class="section">
    <div class="grid cards">
      {pillarPages.map((page) => (
        <article class="card">
          <div class="kicker">pillar page</div>
          <h3><a href={`${baseUrl}dossiers/${page.slug}/`}>{page.title}</a></h3>
          <p>{page.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
