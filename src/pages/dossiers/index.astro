---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { pillarPages } from '../../data/seo';

const basePath = import.meta.env.BASE_URL.replace(/^\/?|\/?$/g, '');
const baseUrl = basePath ? `/${basePath}/` : '/';
---

<BaseLayout
  title="Topics"
  description="Signal IA topic guides that group the strongest coverage by question and theme."
  lang="en"
  ogLocale="en_US"
>
  <section class="list-page-header">
    <div class="eyebrow">Topic guides</div>
    <h1>Topics</h1>
    <p>Deeper pages that group the most useful Signal IA coverage around one question.</p>
  </section>

  <section class="section">
    <div class="grid cards">
      {pillarPages.map((page) => (
        <article class="card">
          <div class="kicker">topic guide</div>
          <h3><a href={`${baseUrl}dossiers/${page.slug}/`}>{page.title}</a></h3>
          <p>{page.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
